# ── Copy this file to backend/.env and fill in your real values ───────────────
# On EC2: cp backend/.env.example backend/.env && nano backend/.env

# ── Database (AWS RDS PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://udhyaam_admin:YOUR_PASSWORD@YOUR_RDS_ENDPOINT.rds.amazonaws.com:5432/udhyaamos

# ── JWT (generate with: openssl rand -hex 32) ─────────────────────────────────
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ── AWS S3 File Storage ───────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=udhyaamos-uploads

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
# No domain? Use: http://YOUR_EC2_ELASTIC_IP:5000/api/auth/google/callback
# With domain: https://api.yourdomain.com/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://YOUR_EC2_ELASTIC_IP:5000/api/auth/google/callback

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS — paste your Vercel URL here (no trailing slash!) ───────────────────
# Get it from: Vercel Dashboard → your project → Deployment URL
# Example: https://udhyaamos-xyz.vercel.app
FRONTEND_URL=https://YOUR-VERCEL-APP.vercel.app

# ── GitHub (optional, for AI features) ───────────────────────────────────────
GITHUB_TOKEN=
